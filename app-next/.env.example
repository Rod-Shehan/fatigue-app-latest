# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fatigue_app"

# NextAuth (required)
NEXTAUTH_SECRET="generate-a-long-random-string"
# Public URL of the app (must match your deployment, e.g. https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Production / staging: shared password for accounts that have no per-user passwordHash in the DB.
# Required for seeded test users unless you set SEED_USER_PASSWORD when running prisma db seed.
NEXTAUTH_CREDENTIALS_PASSWORD=""

# Optional: when set, prisma db seed hashes this and stores it on seed users (bcrypt).
# Can match NEXTAUTH_CREDENTIALS_PASSWORD for convenience.
# SEED_USER_PASSWORD=""
